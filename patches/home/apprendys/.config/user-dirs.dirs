# Apprendys - Dossiers utilisateur XDG
# Tout ce que l'enfant cree/telecharge va sur P5 (DEVOIRS, visible Windows)
# ~/Devoirs est un symlink vers /media/apprendys/DEVOIRS (cree au boot)

XDG_DESKTOP_DIR="$HOME/Bureau"
XDG_DOWNLOAD_DIR="$HOME/Devoirs"
XDG_TEMPLATES_DIR="$HOME/Modeles"
XDG_PUBLICSHARE_DIR="$HOME/Public"
XDG_DOCUMENTS_DIR="$HOME/Devoirs"
XDG_MUSIC_DIR="$HOME/Devoirs/Musique"
XDG_PICTURES_DIR="$HOME/Devoirs/Images"
XDG_VIDEOS_DIR="$HOME/Devoirs/Videos"
